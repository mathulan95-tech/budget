<script>
// ════════════════════════════════════════════════════
// STATE
// ════════════════════════════════════════════════════
const K={tx:'b5_tx',abo:'b5_abo',rec:'b5_rec',pok:'b5_pok',cfg:'b5_cfg'};
let D={tx:[],abo:[],rec:[],pok:[],cfg:{goal:0,iBank:0,iCash:0}};
let cm=new Date().getMonth(),cy=new Date().getFullYear();
let txT='in',txM='bank';
const MO=['Janv','Févr','Mars','Avr','Mai','Juin','Juil','Août','Sept','Oct','Nov','Déc'];
const CAT_COLORS=['#0a84ff','#30d158','#ff9f0a','#ff453a','#bf5af2','#5ac8fa','#ff375f','#5e5ce6','#64d2ff','#ffd60a','#ac8e68'];

function load(){
  const parse=(k,d)=>{try{return JSON.parse(localStorage.getItem(k)||'null')||d;}catch{return d;}};
  D.tx=parse(K.tx,[]);D.abo=parse(K.abo,[]);D.rec=parse(K.rec,[]);D.pok=parse(K.pok,[]);
  const c=parse(K.cfg,{});D.cfg={goal:+c.goal||0,iBank:+c.iBank||0,iCash:+c.iCash||0};
}
function save(){
  Object.keys(K).forEach(k=>localStorage.setItem(K[k],JSON.stringify(D[k==='cfg'?'cfg':k])));
  localStorage.setItem(K.cfg,JSON.stringify(D.cfg));
}

// ════════════════════════════════════════════════════
// NAVIGATION
// ════════════════════════════════════════════════════
function goto(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
  document.getElementById('page-'+id).classList.add('on');
  document.getElementById('nb-'+id).classList.add('on');
  const fab=document.getElementById('fab');
  if(id==='set'){fab.style.display='none';}
  else if(id==='sav'){fab.style.display='none';}
  else if(id==='rec'){fab.style.display='flex';fab.onclick=()=>openOv('rec');}
  else{fab.style.display='flex';fab.onclick=()=>openOv('tx');}
  // secondary fab for rec page abo
  if(id==='dash')renderDash();
  if(id==='tx')renderTxPage();
  if(id==='rec')renderRec();
  if(id==='sav')renderSav();
  if(id==='set')renderSet();
}

// ════════════════════════════════════════════════════
// MONTH
// ════════════════════════════════════════════════════
function chMo(d){cm+=d;if(cm>11){cm=0;cy++;}if(cm<0){cm=11;cy--;}renderDash();}
function inMo(t,m=cm,y=cy){const dt=new Date(t.date||t.created||Date.now());return dt.getMonth()===m&&dt.getFullYear()===y;}

// ════════════════════════════════════════════════════
// SHEET
// ════════════════════════════════════════════════════
function openOv(id){document.getElementById('ov-'+id).classList.add('on');}
function closeOv(e,id){if(e.target.id===id)document.getElementById(id).classList.remove('on');}
function closeAllOv(){document.querySelectorAll('.ov').forEach(o=>o.classList.remove('on'));}

// ════════════════════════════════════════════════════
// FORM HELPERS
// ════════════════════════════════════════════════════
function setT(t){txT=t;document.getElementById('t-in').className='sbtn'+(t==='in'?' s-in':'');document.getElementById('t-out').className='sbtn'+(t==='out'?' s-out':'');}
function setM(m){txM=m;document.getElementById('m-bank').className='sbtn'+(m==='bank'?' s-bank':'');document.getElementById('m-cash').className='sbtn'+(m==='cash'?' s-cash':'');}

// ════════════════════════════════════════════════════
// TRANSACTIONS
// ════════════════════════════════════════════════════
function addTx(){
  const l=v('fl'),a=pf('fa'),d=v('fd'),c=v('fc');
  if(!l||!a||!d){alert('Remplis tous les champs.');return;}
  D.tx.unshift({id:Date.now(),label:l,amount:a,date:d,type:txT,mode:txM,cat:c});
  save();clear('fl','fa');closeAllOv();renderDash();renderTxPage();
}
function delTx(id){if(!confirm('Supprimer ?'))return;D.tx=D.tx.filter(t=>t.id!==id);save();renderTxPage();renderDash();}

// ════════════════════════════════════════════════════
// RÉCURRENTS (charges fixes)
// ════════════════════════════════════════════════════
function recMo(r){
  const a=r.amount;
  if(r.freq==='mensuel')return a;
  if(r.freq==='annuel')return a/12;
  if(r.freq==='trimestriel')return a/3;
  if(r.freq==='hebdo')return a*4.33;
  return a;
}
function addRec(){
  const n=v('rn'),a=pf('ra'),f=v('rf'),e=v('re')||'📋';
  if(!n||!a){alert('Remplis les champs.');return;}
  D.rec.push({id:Date.now(),name:n,amount:a,freq:f,emoji:e});
  save();clear('rn','ra');closeAllOv();renderRec();renderDash();
}
function delRec(id){if(!confirm('Supprimer ?'))return;D.rec=D.rec.filter(r=>r.id!==id);save();renderRec();renderDash();}

// ════════════════════════════════════════════════════
// ABONNEMENTS
// ════════════════════════════════════════════════════
function aboMo(a){return a.freq==='mensuel'?a.amount:a.freq==='annuel'?a.amount/12:a.amount*4.33;}
function addAbo(){
  const n=v('an'),a=pf('aa'),f=v('af'),e=v('ae')||'📦';
  if(!n||!a){alert('Remplis les champs.');return;}
  D.abo.push({id:Date.now(),name:n,amount:a,freq:f,emoji:e});
  save();clear('an','aa');closeAllOv();renderRec();renderDash();
}
function delAbo(id){if(!confirm('Supprimer ?'))return;D.abo=D.abo.filter(a=>a.id!==id);save();renderRec();renderDash();}

// ════════════════════════════════════════════════════
// ÉPARGNE - POCHES
// ════════════════════════════════════════════════════
let activePocket=null,pMoveDir='add';
function addPocket(){
  const n=v('pn'),t=pf('pt')||0,e=v('pe')||'💰';
  if(!n){alert('Donne un nom.');return;}
  D.pok.push({id:Date.now(),name:n,target:t,emoji:e,balance:0,moves:[]});
  save();clear('pn','pt');closeAllOv();renderSav();
}
function openPocketMove(id,dir){
  activePocket=id;pMoveDir=dir;
  document.getElementById('pmove-title').textContent=dir==='add'?'Ajouter de l\'argent':'Retirer de l\'argent';
  document.getElementById('pmove-cta').textContent=dir==='add'?'Ajouter ✓':'Retirer ✓';
  document.getElementById('pmove-cta').onclick=confirmPocketMove;
  document.getElementById('pmove-cta').className='cta '+(dir==='add'?'cta-green':'cta-red');
  openOv('pmove');
}
function confirmPocketMove(){
  const a=pf('pm-amt'),note=v('pm-note')||'';
  if(!a){alert('Montant requis.');return;}
  const pok=D.pok.find(p=>p.id===activePocket);
  if(!pok)return;
  if(pMoveDir==='sub'&&a>pok.balance){alert('Solde insuffisant dans cette poche.');return;}
  pok.balance+=(pMoveDir==='add'?1:-1)*a;
  pok.moves.unshift({dir:pMoveDir,amount:a,note,date:new Date().toISOString()});
  save();clear('pm-amt','pm-note');closeAllOv();renderSav();renderDash();
}
function delPocket(id){if(!confirm('Supprimer cette poche ?'))return;D.pok=D.pok.filter(p=>p.id!==id);save();renderSav();renderDash();}

// ════════════════════════════════════════════════════
// SETTINGS
// ════════════════════════════════════════════════════
function saveSet(){
  D.cfg.goal=pf('s-goal')||0;D.cfg.iBank=pf('s-bank')||0;D.cfg.iCash=pf('s-cash')||0;
  save();renderDash();alert('✓ Enregistré');
}
function renderSet(){
  document.getElementById('s-goal').value=D.cfg.goal||'';
  document.getElementById('s-bank').value=D.cfg.iBank||'';
  document.getElementById('s-cash').value=D.cfg.iCash||'';
}
function resetAll(){if(!confirm('Effacer TOUTES les données ?'))return;D={tx:[],abo:[],rec:[],pok:[],cfg:{goal:0,iBank:0,iCash:0}};save();renderDash();renderTxPage();renderRec();renderSav();}

// ════════════════════════════════════════════════════
// RENDER DASHBOARD
// ════════════════════════════════════════════════════
function renderDash(){
  document.getElementById('mlabel').textContent=MO[cm]+' '+cy;
  const moTx=D.tx.filter(t=>inMo(t));
  const mIn=sum(moTx.filter(t=>t.type==='in'));
  const mOut=sum(moTx.filter(t=>t.type==='out'));
  const net=mIn-mOut;
  const bk=D.cfg.iBank+sum(D.tx.filter(t=>t.type==='in'&&t.mode==='bank'))-sum(D.tx.filter(t=>t.type==='out'&&t.mode==='bank'));
  const cs=D.cfg.iCash+sum(D.tx.filter(t=>t.type==='in'&&t.mode==='cash'))-sum(D.tx.filter(t=>t.type==='out'&&t.mode==='cash'));
  const totalSav=D.pok.reduce((s,p)=>s+p.balance,0);
  const totalRec=D.rec.reduce((s,r)=>s+recMo(r),0)+D.abo.reduce((s,a)=>s+aboMo(a),0);
  const totalAbo=D.abo.reduce((s,a)=>s+aboMo(a),0);

  setText('h-total',fe(bk+cs));
  setText('h-bank',fe(bk));setText('h-cash',fe(cs));
  setText('h-sav',fe(totalSav));setText('h-rec',fe(totalRec));
  setText('k-in',fe(mIn));setText('k-out',fe(mOut));
  const netEl=document.getElementById('k-net');
  netEl.textContent=fe(net);netEl.className='kpi-v '+(net>=0?'c-green':'c-red');
  setText('k-abo',fe(totalAbo));

  // Goal
  const g=D.cfg.goal;const pct=g>0?Math.min(100,Math.round(net/g*100)):0;
  setText('g-pct',g>0?pct+'%':'—');
  const bar=document.getElementById('g-bar');
  bar.style.width=pct+'%';
  bar.style.background=pct>=100?'var(--green)':pct>=60?'var(--blue)':'var(--red)';
  setText('g-sub',g>0?`Objectif ${fe(g)} · Flux net ${fe(net)}`:'Aucun objectif — Réglages');

  // Recent
  const rc=document.getElementById('recent-card');
  const r=D.tx.slice(0,5);
  rc.innerHTML=r.length?r.map(t=>txRow(t,false)).join(''):'<div class="row" style="justify-content:center;color:var(--t3);font-size:14px">Aucune opération</div>';

  // Charts
  renderCashflow();
  renderDonut(moTx.filter(t=>t.type==='out'));
}

// ════════════════════════════════════════════════════
// CASHFLOW CHART (6 mois)
// ════════════════════════════════════════════════════
function renderCashflow(){
  const months=[];
  for(let i=5;i>=0;i--){
    let m=cm-i,y=cy;
    if(m<0){m+=12;y--;}
    months.push({m,y,label:MO[m].slice(0,3)});
  }
  const data=months.map(({m,y,label})=>({
    label,
    in:sum(D.tx.filter(t=>t.type==='in'&&inMo(t,m,y))),
    out:sum(D.tx.filter(t=>t.type==='out'&&inMo(t,m,y)))
  }));
  const maxV=Math.max(...data.map(d=>Math.max(d.in,d.out)),1);
  const container=document.getElementById('cf-bars');
  container.innerHTML=data.map(d=>{
    const inH=Math.round((d.in/maxV)*88);
    const outH=Math.round((d.out/maxV)*88);
    return `<div class="cf-bar-col">
      <div class="cf-bars">
        <div class="cf-bar-in" style="height:${Math.max(inH,2)}px"></div>
        <div class="cf-bar-out" style="height:${Math.max(outH,2)}px"></div>
      </div>
      <div class="cf-bar-lbl">${d.label}</div>
    </div>`;
  }).join('');
}

// ════════════════════════════════════════════════════
// DONUT CHART
// ════════════════════════════════════════════════════
function renderDonut(outTx){
  const canvas=document.getElementById('donut-canvas');
  const ctx=canvas.getContext('2d');
  const legend=document.getElementById('donut-legend');
  ctx.clearRect(0,0,140,140);

  // Group by cat
  const cats={};
  outTx.forEach(t=>{cats[t.cat]=(cats[t.cat]||0)+t.amount;});
  const entries=Object.entries(cats).sort((a,b)=>b[1]-a[1]);
  const total=entries.reduce((s,[,v])=>s+v,0);

  if(!total){
    ctx.fillStyle='rgba(255,255,255,.08)';
    ctx.beginPath();ctx.arc(70,70,56,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='rgba(255,255,255,.15)';
    ctx.beginPath();ctx.arc(70,70,28,0,Math.PI*2);ctx.fill();
    legend.innerHTML='<span style="font-size:12px;color:var(--t3)">Aucune dépense</span>';
    return;
  }

  let startAngle=-Math.PI/2;
  const gap=0.03;
  entries.forEach(([cat,val],i)=>{
    const slice=(val/total)*(Math.PI*2)-gap;
    ctx.beginPath();
    ctx.moveTo(70,70);
    ctx.arc(70,70,56,startAngle,startAngle+slice);
    ctx.closePath();
    ctx.fillStyle=CAT_COLORS[i%CAT_COLORS.length];
    ctx.fill();
    startAngle+=slice+gap;
  });
  // hole
  ctx.beginPath();ctx.arc(70,70,30,0,Math.PI*2);
  ctx.fillStyle='#1c1c1e';ctx.fill();
  // center text
  ctx.fillStyle='rgba(255,255,255,.9)';
  ctx.font='bold 14px -apple-system,sans-serif';
  ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillText(fe(total).replace(',00',''),70,70);

  legend.innerHTML=entries.slice(0,6).map(([cat,val],i)=>`
    <div style="display:flex;align-items:center;gap:6px">
      <div style="width:9px;height:9px;border-radius:50%;background:${CAT_COLORS[i%CAT_COLORS.length]};flex-shrink:0"></div>
      <span style="font-size:12px;color:var(--t2);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${cat}</span>
      <span style="font-size:12px;font-weight:600;color:var(--t1)">${Math.round(val/total*100)}%</span>
    </div>`).join('');
}

// ════════════════════════════════════════════════════
// RENDER MOUVEMENTS
// ════════════════════════════════════════════════════
function renderTxPage(){
  const el=document.getElementById('tx-card');
  el.innerHTML=D.tx.length?D.tx.map(t=>txRow(t,true)).join(''):'<div class="row" style="justify-content:center;color:var(--t3);font-size:14px">Aucune opération</div>';
}

function txRow(t,del){
  const ic=t.type==='in'?{bg:'rgba(48,209,88,.15)',c:'var(--green)',s:'↑'}:{bg:'rgba(255,69,58,.15)',c:'var(--red)',s:'↓'};
  return `<div class="row">
    <div class="row-ico" style="background:${ic.bg};color:${ic.c};font-weight:700;font-size:17px">${ic.s}</div>
    <div class="row-body">
      <div class="row-name">${t.label}</div>
      <div class="row-sub">${t.cat} · <span class="pill pill-${t.mode}">${t.mode==='bank'?'Banque':'Cash'}</span></div>
    </div>
    <div class="row-right">
      <div class="row-val" style="color:${ic.c}">${t.type==='in'?'+':'−'}${fe(t.amount)}</div>
      <div class="row-detail">${fd(t.date)}</div>
    </div>
    ${del?`<button class="row-del" onclick="delTx(${t.id})">✕</button>`:''}
  </div>`;
}

// ════════════════════════════════════════════════════
// RENDER RÉCURRENTS
// ════════════════════════════════════════════════════
function renderRec(){
  const totalRec=D.rec.reduce((s,r)=>s+recMo(r),0);
  const totalAbo=D.abo.reduce((s,a)=>s+aboMo(a),0);
  setText('rec-mo',fe(totalRec));setText('rec-abo',fe(totalAbo));

  // Bouton FAB secondaire pour abonnement dans rec page
  const rc=document.getElementById('rec-card');
  rc.innerHTML=D.rec.length?D.rec.map(r=>`<div class="row">
    <div class="row-ico" style="background:rgba(191,90,242,.15);font-size:17px">${r.emoji}</div>
    <div class="row-body">
      <div class="row-name">${r.name}</div>
      <div class="row-sub">${cap(r.freq)} · ${fe(recMo(r))}/mois</div>
    </div>
    <div class="row-right">
      <div class="row-val c-purple">−${fe(r.amount)}</div>
      <div class="row-detail">${cap(r.freq)}</div>
    </div>
    <button class="row-del" onclick="delRec(${r.id})">✕</button>
  </div>`).join(''):'<div class="row" style="justify-content:center;color:var(--t3);font-size:14px">Aucune charge</div>';

  const ac=document.getElementById('abo-card');
  ac.innerHTML=D.abo.length?D.abo.map(a=>`<div class="row">
    <div class="row-ico" style="background:rgba(255,159,10,.15);font-size:17px">${a.emoji}</div>
    <div class="row-body">
      <div class="row-name">${a.name}</div>
      <div class="row-sub">${cap(a.freq)} · ${fe(aboMo(a))}/mois</div>
    </div>
    <div class="row-right">
      <div class="row-val c-orange">−${fe(a.amount)}</div>
      <div class="row-detail">${cap(a.freq)}</div>
    </div>
    <button class="row-del" onclick="delAbo(${a.id})">✕</button>
  </div>`).join('')+'<div class="row" style="padding:10px 16px"><button class="cta" style="background:var(--s2);color:var(--t2);font-size:14px;padding:11px" onclick="openOv(\'abo\')">＋ Ajouter un abonnement</button></div>'
    :'<div class="row" style="flex-direction:column;gap:10px;padding:14px 16px"><div style="color:var(--t3);font-size:14px">Aucun abonnement</div><button class="cta" style="background:var(--s2);color:var(--t2);font-size:14px;padding:11px" onclick="openOv(\'abo\')">＋ Ajouter un abonnement</button></div>';
}

// ════════════════════════════════════════════════════
// RENDER ÉPARGNE
// ════════════════════════════════════════════════════
function renderSav(){
  const total=D.pok.reduce((s,p)=>s+p.balance,0);
  setText('sav-total',fe(total));
  const el=document.getElementById('pockets-list');
  if(!D.pok.length){
    el.innerHTML='<div style="padding:24px;text-align:center;color:var(--t3);font-size:14px">Aucune poche — crée-en une !</div>';
    return;
  }
  el.innerHTML=D.pok.map(p=>{
    const pct=p.target>0?Math.min(100,Math.round(p.balance/p.target*100)):null;
    const barColor=pct===null?'var(--blue)':pct>=100?'var(--green)':pct>=50?'var(--blue)':'var(--orange)';
    return `<div class="pocket">
      <div class="pocket-head">
        <div style="display:flex;align-items:center;gap:10px">
          <span style="font-size:28px">${p.emoji}</span>
          <div>
            <div class="pocket-name">${p.name}</div>
            ${p.target>0?`<div class="pocket-target">Objectif ${fe(p.target)}</div>`:''}
          </div>
        </div>
        <button class="pocket-btn del" onclick="delPocket(${p.id})" style="background:none;color:var(--t3)">✕</button>
      </div>
      <div class="pocket-amt c-green">${fe(p.balance)}</div>
      ${p.target>0?`<div class="prog-track"><div class="prog-fill" style="width:${pct}%;background:${barColor}"></div></div>
      <div class="pocket-meta"><span>${pct}% atteint</span><span>Reste ${fe(Math.max(0,p.target-p.balance))}</span></div>`:''}
      <div class="pocket-actions">
        <button class="pocket-btn add" onclick="openPocketMove(${p.id},'add')">＋ Ajouter</button>
        <button class="pocket-btn sub" onclick="openPocketMove(${p.id},'sub')">－ Retirer</button>
      </div>
      ${p.moves.length?`<div style="margin-top:10px;border-top:.5px solid var(--sep);padding-top:10px">
        ${p.moves.slice(0,3).map(mv=>`<div style="display:flex;justify-content:space-between;font-size:12px;color:var(--t3);padding:2px 0">
          <span>${mv.note||'Mouvement'} · ${fd(mv.date)}</span>
          <span style="color:${mv.dir==='add'?'var(--green)':'var(--red)'};font-weight:600">${mv.dir==='add'?'+':'−'}${fe(mv.amount)}</span>
        </div>`).join('')}
      </div>`:''}
    </div>`;
  }).join('');
}

// ════════════════════════════════════════════════════
// UTILS
// ════════════════════════════════════════════════════
function v(id){return document.getElementById(id).value;}
function pf(id){return parseFloat(document.getElementById(id).value)||0;}
function setText(id,val){document.getElementById(id).textContent=val;}
function clear(...ids){ids.forEach(id=>document.getElementById(id).value='');}
function sum(arr){return arr.reduce((s,t)=>s+(t.amount||0),0);}
function fe(n){if(isNaN(n))return'—';return n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g,'\u202f').replace('.',',')+'\u202f€';}
function fd(s){if(!s)return'';const d=new Date(s);return d.toLocaleDateString('fr-FR',{day:'2-digit',month:'2-digit'});}
function cap(s){return s?s.charAt(0).toUpperCase()+s.slice(1):'';}

// ════════════════════════════════════════════════════
// INIT
// ════════════════════════════════════════════════════
load();
document.getElementById('fd').value=new Date().toISOString().split('T')[0];
renderDash();
</script>
