    <div class="notch"></div>
    <div class="sheet-title" id="pmove-title">Mouvement</div>
    <div class="sheet-body">
      <div class="field"><label class="f-lbl">Montant (€)</label><input class="f-inp" id="pm-amt" type="number" min="0" step="0.01" placeholder="0,00" inputmode="decimal"/></div>
      <div class="field"><label class="f-lbl">Note (optionnel)</label><input class="f-inp" id="pm-note" placeholder="Virement, Retrait…"/></div>
      <button class="cta" id="pmove-cta" onclick="">Confirmer</button>
