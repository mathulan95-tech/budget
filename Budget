<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Budget</title>
<style>
:root{
  --bg:#000;--s1:#1c1c1e;--s2:#2c2c2e;--s3:#3a3a3c;
  --sep:rgba(255,255,255,.08);--sep2:rgba(255,255,255,.05);
  --t1:#fff;--t2:rgba(255,255,255,.6);--t3:rgba(255,255,255,.3);
  --blue:#0a84ff;--green:#30d158;--red:#ff453a;--orange:#ff9f0a;
  --purple:#bf5af2;--teal:#5ac8fa;--pink:#ff375f;--indigo:#5e5ce6;
  --r:16px;--r-lg:20px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;background:var(--bg);color:var(--t1);font-family:-apple-system,'SF Pro Display','SF Pro Text',sans-serif;font-size:15px;overscroll-behavior:none;-webkit-font-smoothing:antialiased}

/* STRUCTURE */
.safe-top{height:env(safe-area-inset-top,44px)}
.page{display:none;height:calc(100vh - env(safe-area-inset-top,44px) - 54px - env(safe-area-inset-bottom,0px));overflow-y:auto}
.page::-webkit-scrollbar{display:none}
.page.on{display:block}

/* TOPBAR */
.topbar{display:flex;align-items:center;justify-content:space-between;padding:8px 20px 10px}
.topbar-title{font-size:32px;font-weight:700;letter-spacing:-.5px}
.mpill{display:flex;align-items:center;gap:0;background:var(--s2);border-radius:99px;overflow:hidden}
.mpill button{background:none;border:none;color:var(--t2);font-size:18px;cursor:pointer;padding:6px 10px;line-height:1}
.mpill span{font-size:13px;font-weight:600;min-width:80px;text-align:center;letter-spacing:-.1px}

/* TAB BAR */
.tab-bar{position:fixed;bottom:0;left:0;right:0;z-index:200;background:rgba(10,10,10,.88);border-top:.5px solid var(--sep);backdrop-filter:blur(24px) saturate(180%);-webkit-backdrop-filter:blur(24px) saturate(180%);display:flex;padding-bottom:env(safe-area-inset-bottom,0)}
.tab{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:10px 4px 6px;border:none;background:none;color:var(--t3);font-size:10px;font-weight:500;cursor:pointer;letter-spacing:.2px;transition:color .15s}
.tab svg{width:22px;height:22px;stroke:currentColor;stroke-width:1.8;fill:none;stroke-linecap:round;stroke-linejoin:round}
.tab.on{color:var(--blue)}

/* FAB */
.fab{position:fixed;bottom:calc(env(safe-area-inset-bottom,0px) + 66px);right:18px;width:52px;height:52px;background:var(--blue);border:none;border-radius:16px;color:#fff;font-size:28px;cursor:pointer;z-index:190;box-shadow:0 6px 28px rgba(10,132,255,.5);display:flex;align-items:center;justify-content:center;transition:transform .12s;font-weight:300;line-height:1}
.fab:active{transform:scale(.9)}

/* HERO */
.hero{padding:4px 20px 20px}
.hero-lbl{font-size:13px;color:var(--t3);font-weight:500;margin-bottom:4px;letter-spacing:.2px}
.hero-amt{font-size:52px;font-weight:700;letter-spacing:-2px;line-height:1.05;margin-bottom:16px}
.hero-chips{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.chip{background:var(--s1);border-radius:var(--r);padding:13px 15px}
.chip-l{font-size:11px;color:var(--t3);font-weight:500;letter-spacing:.3px;margin-bottom:5px}
.chip-v{font-size:20px;font-weight:700;letter-spacing:-.5px}

/* KPI GRID */
.kpi-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:0 16px;margin-bottom:10px}
.kpi{background:var(--s1);border-radius:var(--r);padding:15px}
.kpi-l{font-size:11px;color:var(--t3);font-weight:500;letter-spacing:.3px;margin-bottom:6px}
.kpi-v{font-size:22px;font-weight:700;letter-spacing:-.5px}

/* SECTION */
.grp{padding:0 16px;margin-bottom:28px}
.grp-title{font-size:13px;color:var(--t3);font-weight:500;letter-spacing:.3px;text-transform:uppercase;margin-bottom:10px;padding-left:2px}
.grp-card{background:var(--s1);border-radius:var(--r-lg);overflow:hidden}

/* ROWS */
.row{display:flex;align-items:center;gap:12px;padding:13px 16px;border-bottom:.5px solid var(--sep);min-height:56px}
.row:last-child{border-bottom:none}
.row-ico{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.row-body{flex:1;min-width:0}
.row-name{font-size:16px;font-weight:400;letter-spacing:-.1px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.row-sub{font-size:12px;color:var(--t3);margin-top:1px}
.row-right{text-align:right;flex-shrink:0}
.row-val{font-size:16px;font-weight:600;letter-spacing:-.3px}
.row-detail{font-size:12px;color:var(--t3);margin-top:1px}
.row-del{background:none;border:none;color:var(--t3);font-size:18px;cursor:pointer;padding:4px 2px 4px 8px;flex-shrink:0}
.row-del:active{color:var(--red)}

/* PILL */
.pill{display:inline-block;padding:2px 8px;border-radius:99px;font-size:10px;font-weight:600;letter-spacing:.3px;text-transform:uppercase}
.pill-bank{background:rgba(10,132,255,.18);color:var(--blue)}
.pill-cash{background:rgba(255,159,10,.18);color:var(--orange)}

/* PROGRESS BAR */
.prog-track{height:5px;background:var(--s3);border-radius:99px;overflow:hidden;margin:8px 0}
.prog-fill{height:100%;border-radius:99px;transition:width .6s cubic-bezier(.4,0,.2,1)}

/* ─── CHART CANVAS ─── */
.chart-wrap{padding:16px 16px 8px}
canvas{display:block}

/* DONUT LEGEND */
.donut-legend{padding:0 16px 16px;display:flex;flex-wrap:wrap;gap:8px}
.dl-item{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--t2)}
.dl-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}

/* SAVINGS POCKET */
.pocket{background:var(--s1);border-radius:var(--r-lg);padding:16px;margin-bottom:10px}
.pocket-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.pocket-name{font-size:16px;font-weight:600}
.pocket-emoji{font-size:22px}
.pocket-meta{display:flex;justify-content:space-between;font-size:13px;color:var(--t3);margin-top:8px}
.pocket-amt{font-size:20px;font-weight:700}
.pocket-target{font-size:13px;color:var(--t3)}
.pocket-actions{display:flex;gap:8px;margin-top:12px}
.pocket-btn{flex:1;padding:9px;background:var(--s2);border:none;border-radius:10px;color:var(--t1);font-size:14px;font-weight:500;cursor:pointer;transition:opacity .12s}
.pocket-btn:active{opacity:.6}
.pocket-btn.add{background:rgba(48,209,88,.18);color:var(--green)}
.pocket-btn.sub{background:rgba(255,69,58,.13);color:var(--red)}
.pocket-btn.del{background:var(--s2);color:var(--t3);flex:none;width:36px}

/* SETTINGS INLINE INPUT */
.row-inp{flex:1;background:transparent;border:none;color:var(--t1);font-size:16px;outline:none;text-align:right;-webkit-appearance:none;min-width:0}
.row-inp::placeholder{color:var(--t3)}
.row-inp::-webkit-inner-spin-button,.row-inp::-webkit-outer-spin-button{-webkit-appearance:none}
.row-unit{font-size:15px;color:var(--t3);flex-shrink:0;margin-left:4px}

/* SHEET */
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:300;align-items:flex-end;backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)}
.ov.on{display:flex}
.sheet{background:#1c1c1e;border-radius:26px 26px 0 0;width:100%;max-width:480px;margin:0 auto;padding-bottom:env(safe-area-inset-bottom,24px);animation:sheetUp .28s cubic-bezier(.34,1.1,.64,1);max-height:92vh;overflow-y:auto}
.sheet::-webkit-scrollbar{display:none}
@keyframes sheetUp{from{transform:translateY(110%)}to{transform:translateY(0)}}
.notch{width:36px;height:5px;background:var(--s3);border-radius:99px;margin:10px auto 16px}
.sheet-title{font-size:20px;font-weight:700;letter-spacing:-.3px;padding:0 20px 14px;border-bottom:.5px solid var(--sep)}
.sheet-body{padding:18px 20px 4px}

/* FORM */
.field{margin-bottom:14px}
.f-lbl{display:block;font-size:12px;font-weight:500;color:var(--t3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px}
.f-inp{width:100%;background:var(--s2);border:none;border-radius:12px;padding:13px 14px;color:var(--t1);font-size:16px;outline:none;-webkit-appearance:none;transition:background .15s}
.f-inp:focus{background:var(--s3)}
.f-sel{width:100%;background:var(--s2);border:none;border-radius:12px;padding:13px 14px;color:var(--t1);font-size:16px;outline:none;-webkit-appearance:none;cursor:pointer}
.seg{display:flex;background:var(--s2);border-radius:12px;padding:3px;gap:3px}
.sbtn{flex:1;padding:9px 4px;border:none;background:none;font-size:13px;font-weight:500;color:var(--t3);cursor:pointer;border-radius:9px;transition:all .15s;white-space:nowrap}
.sbtn.s-in{background:rgba(48,209,88,.22);color:var(--green)}
.sbtn.s-out{background:rgba(255,69,58,.22);color:var(--red)}
.sbtn.s-bank{background:rgba(10,132,255,.22);color:var(--blue)}
.sbtn.s-cash{background:rgba(255,159,10,.22);color:var(--orange)}
.cta{width:100%;padding:15px;background:var(--blue);color:#fff;border:none;border-radius:14px;font-size:17px;font-weight:600;cursor:pointer;margin-top:8px;letter-spacing:-.2px;transition:opacity .12s}
.cta:active{opacity:.75}
.cta-green{background:var(--green)}
.cta-red{background:rgba(255,69,58,.2);color:var(--red)}

/* CASHFLOW BAR CHART */
.cf-bar-wrap{padding:0 16px 16px;display:flex;align-items:flex-end;gap:6px;height:120px}
.cf-bar-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px}
.cf-bars{flex:1;width:100%;display:flex;align-items:flex-end;gap:2px}
.cf-bar-in,.cf-bar-out{flex:1;border-radius:4px 4px 0 0;transition:height .5s cubic-bezier(.4,0,.2,1);min-height:2px}
.cf-bar-in{background:var(--green);opacity:.8}
.cf-bar-out{background:var(--red);opacity:.7}
.cf-bar-lbl{font-size:9px;color:var(--t3);font-weight:500}

/* COLOR UTILS */
.c-green{color:var(--green)}.c-red{color:var(--red)}.c-blue{color:var(--blue)}.c-orange{color:var(--orange)}.c-purple{color:var(--purple)}

/* RECURRING ROW */
.rec-badge{font-size:9px;font-weight:600;letter-spacing:.3px;padding:2px 6px;border-radius:99px;background:rgba(191,90,242,.2);color:var(--purple);text-transform:uppercase;margin-left:4px}
</style>
</head>
<body>
<div class="safe-top"></div>

<!-- ═══════════════════════════════════ DASHBOARD ═══════════════════════════════════ -->
<div class="page on" id="page-dash">
  <div class="topbar">
    <div class="topbar-title">Budget</div>
    <div class="mpill">
      <button onclick="chMo(-1)">‹</button>
      <span id="mlabel">—</span>
      <button onclick="chMo(1)">›</button>
    </div>
  </div>

  <!-- HERO -->
  <div class="hero">
    <div class="hero-lbl">Solde disponible</div>
    <div class="hero-amt" id="h-total">—</div>
    <div class="hero-chips">
      <div class="chip"><div class="chip-l">🏦 Banque</div><div class="chip-v c-blue" id="h-bank">—</div></div>
      <div class="chip"><div class="chip-l">💵 Cash</div><div class="chip-v c-orange" id="h-cash">—</div></div>
      <div class="chip"><div class="chip-l">🎯 Épargne</div><div class="chip-v c-green" id="h-sav">—</div></div>
      <div class="chip"><div class="chip-l">📅 Récurrent</div><div class="chip-v c-purple" id="h-rec">—</div></div>
    </div>
  </div>

  <!-- KPI -->
  <div class="kpi-grid">
    <div class="kpi"><div class="kpi-l">Entrées du mois</div><div class="kpi-v c-green" id="k-in">—</div></div>
    <div class="kpi"><div class="kpi-l">Dépenses du mois</div><div class="kpi-v c-red" id="k-out">—</div></div>
    <div class="kpi"><div class="kpi-l">Flux net</div><div class="kpi-v" id="k-net">—</div></div>
    <div class="kpi"><div class="kpi-l">Abonnements</div><div class="kpi-v c-orange" id="k-abo">—</div></div>
  </div>

  <!-- OBJECTIF EPARGNE -->
  <div style="padding:0 16px;margin-bottom:16px">
    <div style="background:var(--s1);border-radius:var(--r-lg);padding:16px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
        <span style="font-size:15px;font-weight:600">Objectif épargne</span>
        <span style="font-size:22px;font-weight:700;letter-spacing:-.5px" id="g-pct">—</span>
      </div>
      <div class="prog-track"><div class="prog-fill" id="g-bar" style="width:0%"></div></div>
      <div style="font-size:12px;color:var(--t3)" id="g-sub">Aucun objectif — Réglages</div>
    </div>
  </div>

  <!-- CASHFLOW 6 MOIS -->
  <div class="grp">
    <div class="grp-title">Cashflow 6 mois</div>
    <div class="grp-card">
      <div class="chart-wrap" style="padding-bottom:0">
        <div class="cf-bar-wrap" id="cf-bars"></div>
        <div style="display:flex;gap:16px;padding:10px 16px 14px;justify-content:flex-end">
          <span style="font-size:11px;color:var(--green);font-weight:500;display:flex;align-items:center;gap:4px"><span style="width:9px;height:9px;background:var(--green);border-radius:2px;display:inline-block;opacity:.8"></span>Entrées</span>
          <span style="font-size:11px;color:var(--red);font-weight:500;display:flex;align-items:center;gap:4px"><span style="width:9px;height:9px;background:var(--red);border-radius:2px;display:inline-block;opacity:.7"></span>Dépenses</span>
        </div>
      </div>
    </div>
  </div>

  <!-- DONUT CATÉGORIES -->
  <div class="grp">
    <div class="grp-title">Répartition dépenses</div>
    <div class="grp-card">
      <div class="chart-wrap" style="display:flex;align-items:center;justify-content:center;gap:24px">
        <canvas id="donut-canvas" width="140" height="140"></canvas>
        <div id="donut-legend" style="flex:1;display:flex;flex-direction:column;gap:6px;padding-right:8px"></div>
      </div>
    </div>
  </div>

  <!-- RECENTES -->
  <div class="grp">
    <div class="grp-title">Dernières opérations</div>
    <div class="grp-card" id="recent-card">
      <div class="row" style="justify-content:center;color:var(--t3);font-size:14px">Aucune opération</div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════ MOUVEMENTS ═══════════════════════════════════ -->
<div class="page" id="page-tx">
  <div class="topbar"><div class="topbar-title">Mouvements</div></div>
  <div class="grp">
    <div class="grp-card" id="tx-card">
      <div class="row" style="justify-content:center;color:var(--t3);font-size:14px">Aucune opération</div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════ RÉCURRENTS ═══════════════════════════════════ -->
<div class="page" id="page-rec">
  <div class="topbar"><div class="topbar-title">Récurrents</div></div>

  <!-- SUMMARY -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:0 16px;margin-bottom:10px">
    <div class="kpi"><div class="kpi-l">Charges fixes/mois</div><div class="kpi-v c-purple" id="rec-mo">—</div></div>
    <div class="kpi"><div class="kpi-l">Abonnements/mois</div><div class="kpi-v c-orange" id="rec-abo">—</div></div>
  </div>

  <div class="grp">
    <div class="grp-title">Charges fixes (loyer, essence…)</div>
    <div class="grp-card" id="rec-card">
      <div class="row" style="justify-content:center;color:var(--t3);font-size:14px">Aucune charge</div>
    </div>
  </div>

  <div class="grp">
    <div class="grp-title">Abonnements</div>
    <div class="grp-card" id="abo-card">
      <div class="row" style="justify-content:center;color:var(--t3);font-size:14px">Aucun abonnement</div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════ ÉPARGNE ═══════════════════════════════════ -->
<div class="page" id="page-sav">
  <div class="topbar"><div class="topbar-title">Épargne</div></div>

  <!-- TOTAL EPARGNE -->
  <div class="hero" style="padding-top:0;padding-bottom:12px">
    <div class="hero-lbl">Total épargné</div>
    <div class="hero-amt c-green" id="sav-total">—</div>
  </div>

  <div class="grp" style="margin-bottom:0">
    <div class="grp-title">Mes poches</div>
    <div id="pockets-list"></div>
    <div style="margin-top:10px">
      <button class="cta cta-green" onclick="openOv('pocket')">＋ Nouvelle poche</button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════ RÉGLAGES ═══════════════════════════════════ -->
<div class="page" id="page-set">
  <div class="topbar"><div class="topbar-title">Réglages</div></div>

  <div class="grp">
    <div class="grp-title">Objectif mensuel</div>
    <div class="grp-card">
      <div class="row">
        <div class="row-body"><div class="row-name">Épargne mensuelle</div></div>
        <input class="row-inp" id="s-goal" type="number" min="0" placeholder="500" inputmode="numeric"/>
        <div class="row-unit">€</div>
      </div>
    </div>
  </div>

  <div class="grp">
    <div class="grp-title">Solde de départ</div>
    <div class="grp-card">
      <div class="row">
        <div class="row-body"><div class="row-name">Banque</div></div>
        <input class="row-inp" id="s-bank" type="number" step="0.01" placeholder="0,00" inputmode="decimal"/>
        <div class="row-unit">€</div>
      </div>
      <div class="row">
        <div class="row-body"><div class="row-name">Cash</div></div>
        <input class="row-inp" id="s-cash" type="number" step="0.01" placeholder="0,00" inputmode="decimal"/>
        <div class="row-unit">€</div>
      </div>
    </div>
  </div>

  <div style="padding:0 16px">
    <button class="cta" onclick="saveSet()">Enregistrer</button>
    <button class="cta cta-red" style="margin-top:10px" onclick="resetAll()">Tout effacer</button>
  </div>
</div>

<!-- ═══════════════ TAB BAR ═══════════════ -->
<nav class="tab-bar">
  <button class="tab on" id="nb-dash" onclick="goto('dash')">
    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
    Tableau
  </button>
  <button class="tab" id="nb-tx" onclick="goto('tx')">
    <svg viewBox="0 0 24 24"><path d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>
    Flux
  </button>
  <button class="tab" id="nb-rec" onclick="goto('rec')">
    <svg viewBox="0 0 24 24"><path d="M12 2v10l4 4"/><circle cx="12" cy="12" r="10"/></svg>
    Récurrents
  </button>
  <button class="tab" id="nb-sav" onclick="goto('sav')">
    <svg viewBox="0 0 24 24"><path d="M20 12V8H4v4M4 8l2-4h12l2 4M12 12v8m-4-4h8"/><circle cx="17" cy="17" r="3"/></svg>
    Épargne
  </button>
  <button class="tab" id="nb-set" onclick="goto('set')">
    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
    Réglages
  </button>
</nav>

<button class="fab" id="fab" onclick="openOv('tx')">＋</button>

<!-- ══════════ SHEET: OPÉRATION ══════════ -->
<div class="ov" id="ov-tx" onclick="closeOv(event,'ov-tx')">
  <div class="sheet">
    <div class="notch"></div>
